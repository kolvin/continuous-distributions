root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.cs]
indent_size = 4

# Naming conventions -------------------------------------------------------
# Interfaces must be prefixed with I
dotnet_naming_rule.interface_should_be_prefixed.severity = warning
dotnet_naming_rule.interface_should_be_prefixed.symbols = interface
dotnet_naming_rule.interface_should_be_prefixed.style = prefix_interface_with_i

dotnet_naming_symbols.interface.applicable_kinds = interface
dotnet_naming_symbols.interface.applicable_accessibilities = public, internal

dotnet_naming_style.prefix_interface_with_i.required_prefix = I
dotnet_naming_style.prefix_interface_with_i.capitalization = pascal_case

# Private fields use _camelCase
dotnet_naming_rule.private_fields_should_be_camel_case.severity = warning
dotnet_naming_rule.private_fields_should_be_camel_case.symbols = private_fields
dotnet_naming_rule.private_fields_should_be_camel_case.style = camel_case_underscore_prefix

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

dotnet_naming_style.camel_case_underscore_prefix.required_prefix = _
dotnet_naming_style.camel_case_underscore_prefix.capitalization = camel_case

# Code style ---------------------------------------------------------------
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

csharp_prefer_braces = true:warning
csharp_style_expression_bodied_methods = false:none
csharp_new_line_before_open_brace = all
csharp_style_namespace_declarations = file_scoped:warning

dotnet_style_qualification_for_field = false:warning
dotnet_style_qualification_for_property = false:warning
dotnet_style_prefer_collection_expression = true:suggestion
dotnet_sort_system_directives_first = true

# Unnecessary code ---------------------------------------------------------
dotnet_diagnostic.IDE0051.severity = warning   # unused private member
dotnet_diagnostic.IDE0052.severity = warning   # unread private member
dotnet_diagnostic.IDE0055.severity = warning   # formatting rule violations
dotnet_diagnostic.IDE0060.severity = warning   # unused parameter

# StyleCop rules (SA*) -----------------------------------------------------
# Relaxed rules that are too noisy for a small project
dotnet_diagnostic.SA1101.severity = none       # do not require 'this.'
dotnet_diagnostic.SA1633.severity = none       # no file header required
dotnet_diagnostic.SA1200.severity = none       # using directives inside/outside namespace
dotnet_diagnostic.SA1600.severity = suggestion # public members should have XML docs
dotnet_diagnostic.SA1602.severity = suggestion # enum items should have XML docs
dotnet_diagnostic.SA1309.severity = none       # conflicts with our _camelCase field convention
dotnet_diagnostic.SA0001.severity = none       # XML doc generation not required globally

# Test project — relax rules that conflict with xUnit idioms
[Distributions.Test/**/*.cs]
dotnet_diagnostic.CA1707.severity = none # underscore test names (Method_Condition_Result) are xUnit convention

# Console project — no resource file, so literal strings in WriteLine are fine
[Distributions.Console/**/*.cs]
dotnet_diagnostic.CA1303.severity = none # no globalisation resource table in a simple CLI

[*.{json,yml,yaml}]
indent_size = 2

[Makefile]
indent_style = tab
